# ==============================================================================
# Customer Support Operations Intelligence Platform - Environment Variables
# ==============================================================================

# --- PostgreSQL Configuration ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=support_ops_intel

# --- Ingestion Configuration ---
# Raw data ingestion schema
DB_RAW_SCHEMA=raw

# --- DBT Configuration ---
# Path to where dbt profiles.yml is located (relative or absolute)
DBT_PROFILES_DIR=./warehouse

# --- Python Environment ---
# Add root project directory to PYTHONPATH
PYTHONPATH=.
